# Used by sign-in and account-settings E2E specs (same credentials). Playwright loads from either:
#   - `.env.e2e.local` in the repo root (create by copying this file — it is gitignored), or
#   - `.env.local` — only lines whose names start with `E2E_` are picked up for tests.
#
# Use a dedicated non-production test user in the same Supabase project as
# `NEXT_PUBLIC_SUPABASE_*` in `.env.local`.

E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PASSWORD=

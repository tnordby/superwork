# Copy to `.env.local` for local development (never commit real secrets).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google sign-in (Supabase Auth): Dashboard → Authentication → Providers → Google (Client ID + secret).
# Dashboard → Authentication → URL configuration: add https://<your-domain>/auth/callback and
# http://localhost:3000/auth/callback (same path as NEXT_PUBLIC_APP_URL origin).

# Stripe (test: sk_test_ / pk_test_; live: sk_live_ / pk_live_ — never mix live keys with test IDs in the DB)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Signing secret from Dashboard → Webhooks → your endpoint (live endpoint needs whsec_ from live mode; Stripe CLI forwarding uses a different secret)
STRIPE_WEBHOOK_SECRET=

# Product ID for capacity checkout & subscription changes — must exist in the same Stripe mode as STRIPE_SECRET_KEY (create/copy the product in Live mode for production).
STRIPE_SUPERWORK_CAPACITY_PRODUCT_ID=

# Email (Resend)
RESEND_API_KEY=

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# E2E (Playwright) — optional; see playwright.config.ts and e2e/auth-helpers.ts
# E2E_TEST_USER_EMAIL=
# E2E_TEST_USER_PASSWORD=
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Removed: ONBOARDING_* (HubSpot link / survey / doc URLs for the old in-app checklist).
# Customer onboarding is handled outside the app; delete those vars from Vercel/hosting if still present.

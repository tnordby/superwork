# Copy to `.env.local` for local development (never commit real secrets).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google sign-in (Supabase Auth): Dashboard → Authentication → Providers → Google (Client ID + secret).
# Dashboard → Authentication → URL configuration: add https://<your-domain>/auth/callback and
# http://localhost:3000/auth/callback (same path as NEXT_PUBLIC_APP_URL origin).

# Stripe — Checkout, Customer Portal, and API calls all follow STRIPE_SECRET_KEY mode (test vs live): use sk_test_/pk_test_/test webhook whsec_/test prod_… together, or sk_live_/pk_live_/live webhook/live prod_… together; never mix (wrong portal, missing product, or “no such customer” errors). STRIPE_SUPERWORK_CAPACITY_PRODUCT_ID is the Dashboard Products ID for capacity flows and must match the same mode as the secret key.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUPERWORK_CAPACITY_PRODUCT_ID=

# Email (Resend)
RESEND_API_KEY=

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# E2E (Playwright) — optional; see playwright.config.ts and e2e/auth-helpers.ts
# E2E_TEST_USER_EMAIL=
# E2E_TEST_USER_PASSWORD=
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Removed: ONBOARDING_* (HubSpot link / survey / doc URLs for the old in-app checklist).
# Customer onboarding is handled outside the app; delete those vars from Vercel/hosting if still present.
